{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
  "id": "yandex-alice-device-dial",
  "items": [
    {
      "key": "icon",
      "type": "pixmap",
      "rect": [8, 10, 36, 36]
    },
    {
      "key": "title",
      "type": "text",
      "rect": [48, 8, 144, 16],
      "alignment": "left",
      "font": { "size": 12, "weight": 600 },
      "color": "#DDD6FE"
    },
    {
      "key": "value",
      "type": "text",
      "rect": [48, 26, 144, 28],
      "alignment": "left",
      "font": { "size": 24, "weight": 700 },
      "color": "#F5F3FF"
    },
    {
      "key": "subtitle",
      "type": "text",
      "rect": [8, 58, 184, 14],
      "alignment": "left",
      "font": { "size": 11, "weight": 500 },
      "color": "#C4B5FD"
    },
    {
      "key": "bar",
      "type": "bar",
      "rect": [8, 78, 184, 14],
      "value": 0,
      "subtype": 4,
      "border_w": 0,
      "bar_bg_c": "#4C1D95",
      "bar_fill_c": "0:#C026FF,1:#A855F7"
    }
  ]
}
