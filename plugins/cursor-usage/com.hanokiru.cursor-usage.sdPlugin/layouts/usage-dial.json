{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
  "id": "cursor-usage-dial",
  "items": [
    {
      "key": "title",
      "type": "text",
      "rect": [10, 6, 180, 18],
      "alignment": "center",
      "font": { "size": 13, "weight": 600 },
      "color": "#DDD6FE"
    },
    {
      "key": "value",
      "type": "text",
      "rect": [10, 24, 180, 36],
      "alignment": "center",
      "font": { "size": 28, "weight": 700 },
      "color": "#F5F3FF"
    },
    {
      "key": "subtitle",
      "type": "text",
      "rect": [10, 60, 180, 16],
      "alignment": "center",
      "font": { "size": 11, "weight": 500 },
      "color": "#C4B5FD"
    },
    {
      "key": "bar",
      "type": "bar",
      "rect": [14, 82, 172, 12],
      "value": 0,
      "subtype": 4,
      "border_w": 0,
      "bar_bg_c": "#4C1D95",
      "bar_fill_c": "0:#A78BFA,1:#7C3AED"
    }
  ]
}
